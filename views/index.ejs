<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description"
    content="Lean SQL-Gen — Convert business criteria into SQL using AI-powered schema-aware generation." />
  <title>SaktiSQL-Gen — AI-Powered SQL Generator</title>

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
    rel="stylesheet" />

  <link rel="stylesheet" href="/css/style.css" />
</head>

<body>
  <!-- Animated background orbs -->
  <div class="bg-orb bg-orb--1"></div>
  <div class="bg-orb bg-orb--2"></div>
  <div class="bg-orb bg-orb--3"></div>

  <div class="app" id="app">
    <!-- Header -->
    <header class="header">
      <div class="header__brand">
        <div class="header__icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
            stroke-linecap="round" stroke-linejoin="round">
            <polyline points="16 18 22 12 16 6"></polyline>
            <polyline points="8 6 2 12 8 18"></polyline>
          </svg>
        </div>
        <h1 class="header__title">SaktiSQL-Gen</h1>
      </div>
      <p class="header__subtitle">Transform business questions into SQL — powered by arinda</p>
    </header>

    <!-- Main Content -->
    <main class="main">
      <!-- Input Panel -->
      <section class="panel panel--input" id="input-panel">
        <div class="panel__header">
          <h2 class="panel__title">
            <span class="panel__title-icon">💬</span>
            Ask in Plain English
          </h2>
        </div>
        <div class="panel__body">
          <textarea id="query-input" class="input-area"
            placeholder="e.g. Show total revenue by store for Q3 2024, sorted by highest revenue first..."
            rows="4"></textarea>
          <div class="input-actions">
            <div class="input-hint">
              <span class="input-hint__icon">💡</span>
              <span>Tip: Be specific with time periods, groupings, and sort order for best results.</span>
            </div>
            <button id="generate-btn" class="btn btn--primary" type="button">
              <span class="btn__text">Generate SQL</span>
              <span class="btn__loader" aria-hidden="true">
                <span class="spinner"></span>
              </span>
              <svg class="btn__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
              </svg>
            </button>
          </div>
        </div>
      </section>

      <!-- Output Panel -->
      <section class="panel panel--output" id="output-panel">
        <div class="panel__header">
          <h2 class="panel__title">
            <span class="panel__title-icon">🗄️</span>
            Generated SQL
          </h2>
          <div class="panel__actions">
            <button id="copy-btn" class="btn btn--ghost" type="button" title="Copy to clipboard" style="display:none;">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                stroke-linecap="round" stroke-linejoin="round">
                <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
              </svg>
              <span id="copy-btn-text">Copy</span>
            </button>
          </div>
        </div>
        <div class="panel__body">
          <!-- Empty state -->
          <div id="output-empty" class="output-empty">
            <div class="output-empty__icon">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"
                stroke-linecap="round" stroke-linejoin="round" opacity="0.3">
                <polyline points="16 18 22 12 16 6"></polyline>
                <polyline points="8 6 2 12 8 18"></polyline>
              </svg>
            </div>
            <p>Your generated SQL will appear here</p>
          </div>
          <!-- SQL result -->
          <pre id="output-code" class="code-block" style="display:none;"><code id="sql-output"></code></pre>
          <!-- Error state -->
          <div id="output-error" class="output-error" style="display:none;">
            <span class="output-error__icon">⚠️</span>
            <p id="error-message"></p>
          </div>
        </div>
      </section>
    </main>

    <!-- Schema Sidebar Toggle -->
    <button id="schema-toggle" class="schema-toggle" type="button" title="View database schema">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
        stroke-linecap="round" stroke-linejoin="round">
        <ellipse cx="12" cy="5" rx="9" ry="3"></ellipse>
        <path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"></path>
        <path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"></path>
      </svg>
      <span>Schema</span>
    </button>

    <!-- Schema Sidebar -->
    <aside id="schema-sidebar" class="sidebar">
      <div class="sidebar__header">
        <h2 class="sidebar__title">📋 Database Schema</h2>
        <button id="schema-close" class="btn btn--icon" type="button" title="Close schema">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
            stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>
      <div id="schema-content" class="sidebar__content">
        <div class="sidebar__loading">
          <span class="spinner"></span>
          <p>Loading schema…</p>
        </div>
      </div>
    </aside>

    <!-- Sidebar overlay -->
    <div id="sidebar-overlay" class="sidebar-overlay"></div>
  </div>

  <script src="/js/app.js"></script>
</body>

</html>